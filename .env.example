# ─────────────────────────────────────────────────────────────
#  Dia — environment configuration
#  Copy to `.env` and fill in. This one file is your credential +
#  config source for every run mode: native (`make api`/`worker`/
#  `web`), the hot-reload Docker stack (`make app`), and the full
#  self-hostable stack (`make stack`). The Docker stacks read it
#  directly, overriding only the infra URLs below with in-network
#  hostnames (so `localhost` here is correct for native runs).
# ─────────────────────────────────────────────────────────────

# ── Discord application ──────────────────────────────────────
DISCORD_TOKEN=                # Bot token
DISCORD_CLIENT_ID=            # Application (client) ID — used for OAuth2 + slash registration
DISCORD_CLIENT_SECRET=        # OAuth2 client secret (dashboard login)
DISCORD_PUBLIC_KEY=           # Ed25519 public key (only if using HTTP interactions; gateway path doesn't need it)

# ── Gateway / sharding (Elixir) ──────────────────────────────
# SHARD_COUNT=auto  -> ask Discord for the recommended count
SHARD_COUNT=auto
# Horizontal scale: each gateway node owns shards where (shard_id % NODE_COUNT) == NODE_INDEX
NODE_INDEX=0
NODE_COUNT=1
# Gateway intents are configured in gateway/config; privileged intents must be enabled in the Discord dev portal:
#   GUILD_MEMBERS (welcome/leveling/autorole), MESSAGE_CONTENT (automod)

# ── NATS JetStream (event bus) ───────────────────────────────
NATS_URL=nats://localhost:4222
NATS_STREAM=DIA_EVENTS        # JetStream stream name for forwarded gateway events

# ── PostgreSQL ───────────────────────────────────────────────
DATABASE_URL=postgres://dia:dia@localhost:5432/dia?sslmode=disable
PG_MAX_CONNS=10

# ── Redis (cache + locks + realtime fan-out) ─────────────────
REDIS_URL=redis://localhost:6379/0

# ── API (Go / gin) ───────────────────────────────────────────
API_ADDR=:8080
API_BASE_URL=http://localhost:8080      # Public URL of the API
WEB_BASE_URL=http://localhost:5173      # Public URL of the dashboard (CORS + post-login redirect)
# Extra browser origins allowed by CORS (comma-separated). Empty = just
# WEB_BASE_URL. Set this to reach the dashboard off-box, e.g. over Tailscale:
#   CORS_ALLOW_ORIGINS=http://100.x.y.z:5173,http://localhost:5173
# The `make run/web/api PUBLIC_HOST=<ip>` targets set this for you.
CORS_ALLOW_ORIGINS=
OAUTH_REDIRECT_PATH=/auth/callback      # Joined with WEB_BASE_URL (the dashboard handles the OAuth callback)
SESSION_SECRET=change-me-32-bytes-min   # Signs session cookies (use `openssl rand -hex 32`)
SESSION_COOKIE_NAME=dia_session

# ── Web (SvelteKit, build-time PUBLIC_*) ─────────────────────
PUBLIC_API_URL=http://localhost:8080
PUBLIC_WS_URL=ws://localhost:8080/realtime

# ── Imaging ──────────────────────────────────────────────────
FONTS_DIR=./assets/fonts          # run `make fonts` for the full font roster (Lato is embedded)
# The renderer refuses to fetch images/avatars/fonts from private/loopback/
# link-local IPs (SSRF guard). Set true ONLY in dev if your object store is on
# localhost (e.g. MinIO) and the server must fetch custom fonts from it.
IMAGING_ALLOW_PRIVATE_FETCH=false

# ── Object storage (image + custom-font uploads) ─────────────
# S3-compatible: AWS S3, Cloudflare R2, MinIO, DigitalOcean Spaces. Leave empty
# to disable uploads (the dashboard then offers URL-only image fields).
S3_ENDPOINT=                      # e.g. https://s3.eu-west-1.amazonaws.com or https://<acct>.r2.cloudflarestorage.com
S3_REGION=us-east-1               # "auto" for R2
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_PUBLIC_BASE_URL=               # CDN / custom domain assets are served from; empty = derive from endpoint+bucket
S3_FORCE_PATH_STYLE=false         # true for MinIO and most non-AWS S3-compatible stores
S3_OBJECT_ACL=                    # e.g. public-read for AWS public buckets (leave empty for R2)

# ── Billing (Stripe — $3.99/mo premium) ──────────────────────
# Leave empty to disable billing; premium then comes only from PREMIUM_GUILD_IDS.
STRIPE_SECRET_KEY=                # sk_live_… / sk_test_…
STRIPE_WEBHOOK_SECRET=            # whsec_… (point a Stripe webhook at /billing/webhook)
STRIPE_PRICE_ID=                  # the recurring $3.99/mo Price id
# Manual premium override (comma-separated guild ids) — handy for dev/staff.
PREMIUM_GUILD_IDS=

# ── Misc ─────────────────────────────────────────────────────
LOG_LEVEL=info               # debug | info | warn | error
ENV=development              # development | production

# ── Local development ────────────────────────────────────────
# Register slash commands to a single guild for instant updates (global
# registration takes ~1h to propagate). Leave empty for global.
DEV_GUILD_ID=
# `make seed` loads fixture data onto this guild. Set it to a guild you own so
# the seeded config shows up in the dashboard. Empty = a built-in fake guild.
SEED_GUILD_ID=
